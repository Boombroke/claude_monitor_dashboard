{
  "name": "ccmon",
  "version": "0.1.0",
  "description": "本地 Claude Code 会话监控 + 通知中心 — watch all local `claude` CLI sessions and get notified when one needs approval, finishes, or is waiting on you.",
  "type": "module",
  "bin": {
    "ccmon": "./src/cli.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/cli.ts start",
    "start": "node src/cli.ts start",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test 'test/**/*.test.ts'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "monitor",
    "notifications",
    "ntfy",
    "pwa",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "chokidar": "^4.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
